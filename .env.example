# ─────────────────────────────────────────
# CANARY BLAIR — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────

# ── Sync Worker (pipeline/sync.js) ──────
LEGISCAN_API_KEY=            # LegiScan API key (free at legiscan.com/legiscan)
SUPABASE_URL=                # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=        # Service role key (never the anon key)
SYNC_SECRET=                 # Random secret for manual HTTP trigger auth
AI_QUEUE_URL=                # URL of the deployed ai-worker (set after deploying ai-worker)

# ── AI Worker (pipeline/ai-worker.js) ───
ANTHROPIC_API_KEY=           # Anthropic API key (pay-as-you-go, from console.anthropic.com)

# ── Campaign finance (pipeline/finance.js, optional) ───
FTM_API_KEY=                 # FollowTheMoney/OpenSecrets key (free at followthemoney.org) — enables money-in-politics

# ── SvelteKit Frontend ──────────────────
PUBLIC_SUPABASE_URL=         # Same Supabase project URL (public, safe to expose)
PUBLIC_SUPABASE_ANON_KEY=    # Anon key (public, safe to expose — RLS protects data)
